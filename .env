DATABASE_URL=postgresql://diary_user:diary_password@db:5432/diarydb
SECRET_KEY=your-secret-key-change-in-production
UPLOAD_FOLDER=static/uploads

# OpenRouter / OpenAI settings
# Set your OpenRouter API key (required to use AI features)
OPENROUTER_API_KEY=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
# Optional: base URL for OpenRouter-compatible API (defaults to https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: model to use (defaults to openai/gpt-3.5-turbo)
OPENROUTER_MODEL=openai/gpt-3.5-turbo
# Optional: your site URL for OpenRouter rankings (defaults to http://localhost:5000)
SITE_URL=http://localhost:5000
# Optional: your site name for OpenRouter rankings (defaults to Electronic Diary)
SITE_NAME=Electronic Diary
# Optional: set to "1" to disable AI chat feature
DISABLE_AI_CHAT=0